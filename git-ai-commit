#!/bin/bash

# git-ai-commit - Generate commit messages using AI based on git diff
# Usage: git-ai-commit [options]

set -e

# Default values
STAGED_ONLY=true
ALL_CHANGES=false
INCLUDE_CONTEXT=false
DRY_RUN=false
AI_PROVIDER="openai"
MAX_DIFF_LINES=500
DEBUG_MODE="${DEBUG:-false}"
CONFIG_FILE="${HOME}/.ai-commit-cli/config.json"
COMMIT_MESSAGE_FILE=""

# API Configuration - can be overridden by environment variables
CLAUDE_API_URL="${CLAUDE_API_URL:-https://api.anthropic.com/v1/messages}"
OPENAI_API_URL="${OPENAI_API_URL:-https://api.openai.com/v1/chat/completions}"
GEMINI_API_URL="${GEMINI_API_URL:-https://generativelanguage.googleapis.com/v1beta}"
CLAUDE_MODEL="claude-3-sonnet-20240229"
OPENAI_MODEL="gpt-4"
GEMINI_MODEL="gemini-2.5-flash"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Print debug message
debug() {
    if [[ "$DEBUG_MODE" == "true" || "$DEBUG_MODE" == "1" ]]; then
        echo -e "${MAGENTA}DEBUG: $1${NC}" >&2
    fi
}

# Print usage information
show_help() {
    cat << EOF
git-ai-commit - Generate commit messages using AI based on git diff

USAGE:
    git-ai-commit [OPTIONS]

OPTIONS:
    -s, --staged        Analyze staged changes (default behavior; kept for compatibility)
    -a, --all           Stage all changes before analysis and commit
    -c, --context       Include more context in the analysis
    -d, --dry-run       Show the commit message without committing
    -p, --provider      AI provider to use (claude, openai, gemini) [default: openai]
    -l, --limit         Maximum per-run patch excerpt lines for large diffs [default: 500]
    -h, --help          Show this help message

EXAMPLES:
    git-ai-commit                    # Analyze staged changes and commit
    git-ai-commit --staged           # Same as default, kept for compatibility
    git-ai-commit --all              # Stage all changes, then analyze and commit them
    git-ai-commit --dry-run          # Show commit message without committing
    git-ai-commit --context          # Include more context in analysis

REQUIREMENTS:
    - git repository
    - curl or wget for HTTP requests
    - API key configured (ANTHROPIC_API_KEY, OPENAI_API_KEY, or GEMINI_API_KEY)
    - Active git changes to analyze

ENVIRONMENT VARIABLES:
    ANTHROPIC_API_KEY    API key for Claude (required for claude provider)
    OPENAI_API_KEY       API key for OpenAI (required for openai provider)
    GEMINI_API_KEY       API key for Gemini (required for gemini provider)
                         - Keys starting with 'sk-' use OpenAI-compatible API format
                         - Other keys use Google AI Gemini API format
    GIT_AI_COMMIT_MODEL  Override default model
    CLAUDE_API_URL       Override Claude API URL or base URL
    OPENAI_API_URL       Override OpenAI API URL or base URL
    GEMINI_API_URL       Override Gemini API URL or base URL
    DEBUG                Enable debug logging (true/1 to enable)

CONFIG FILE:
    Default path: ~/.ai-commit-cli/config.json
    Priority: command line > config file > environment variables > built-in defaults

EOF
}

# Print error message and exit
error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

# Print info message
info() {
    echo -e "${BLUE}Info: $1${NC}"
}

# Print success message
success() {
    echo -e "${GREEN}Success: $1${NC}"
}

# Print warning message
warn() {
    echo -e "${YELLOW}Warning: $1${NC}"
}

print_commit_message_preview() {
    local commit_message="$1"
    local line=""
    local printed_subject=false

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ -z "$line" ]]; then
            echo
            continue
        fi

        if [[ "$printed_subject" == "false" ]]; then
            echo -e "${YELLOW}$line${NC}"
            printed_subject=true
            continue
        fi

        if [[ "$line" =~ ^-([[:space:]]+)(.*[[:space:]])\[([^][]+)\][[:space:]]*$ ]]; then
            echo -e "-${BASH_REMATCH[1]}${YELLOW}${BASH_REMATCH[2]}${NC}[${CYAN}${BASH_REMATCH[3]}${NC}]"
        else
            echo -e "${YELLOW}$line${NC}"
        fi
    done <<< "$commit_message"
}

cleanup_commit_message_file() {
    if [[ -n "$COMMIT_MESSAGE_FILE" && -f "$COMMIT_MESSAGE_FILE" ]]; then
        rm -f "$COMMIT_MESSAGE_FILE"
    fi
}

prepare_commit_scope() {
    if [[ "$ALL_CHANGES" == "true" ]]; then
        info "Staging all changes before analysis..."
        debug "Running: git add -A"
        git add -A
    fi
}

trim_trailing_slash() {
    local url="$1"
    echo "${url%/}"
}

resolve_openai_api_url() {
    local configured_url="$1"
    local normalized_url

    normalized_url=$(trim_trailing_slash "$configured_url")

    case "$normalized_url" in
        */chat/completions)
            echo "$normalized_url"
            ;;
        */v1)
            echo "${normalized_url}/chat/completions"
            ;;
        *)
            echo "${normalized_url}/v1/chat/completions"
            ;;
    esac
}

resolve_claude_api_url() {
    local configured_url="$1"
    local normalized_url

    normalized_url=$(trim_trailing_slash "$configured_url")

    case "$normalized_url" in
        */v1/messages)
            echo "$normalized_url"
            ;;
        */v1)
            echo "${normalized_url}/messages"
            ;;
        *)
            echo "${normalized_url}/v1/messages"
            ;;
    esac
}

resolve_gemini_api_url() {
    local configured_url="$1"
    trim_trailing_slash "$configured_url"
}

normalize_provider_api_urls() {
    CLAUDE_API_URL=$(resolve_claude_api_url "$CLAUDE_API_URL")
    OPENAI_API_URL=$(resolve_openai_api_url "$OPENAI_API_URL")
    GEMINI_API_URL=$(resolve_gemini_api_url "$GEMINI_API_URL")
}

ensure_config_file() {
    local config_dir
    config_dir=$(dirname "$CONFIG_FILE")

    if [[ -f "$CONFIG_FILE" ]]; then
        return 0
    fi

    mkdir -p "$config_dir"

    cat > "$CONFIG_FILE" << EOF
{
  "provider": "openai",
  "model": "gpt-4",
  "base_url": "https://api.openai.com",
  "api_key": ""
}
EOF

    info "Created default config file: $CONFIG_FILE"
}

load_config() {
    ensure_config_file

    if ! command -v jq &> /dev/null; then
        error "jq is required to read config file: $CONFIG_FILE"
    fi

    debug "Loading config file: $CONFIG_FILE"

    local config_provider=""
    config_provider=$(jq -r '.provider // empty' "$CONFIG_FILE")

    if [[ -n "$config_provider" && -z "${CLI_PROVIDER_SET:-}" ]]; then
        AI_PROVIDER="$config_provider"
    fi

    local config_scope=".providers.${AI_PROVIDER}"
    local allow_top_level_fallback="false"
    if [[ -z "$config_provider" || "$config_provider" == "$AI_PROVIDER" ]]; then
        allow_top_level_fallback="true"
    fi

    local config_api_key=""
    local config_model=""
    local config_base_url=""

    config_api_key=$(jq -r "${config_scope}.api_key // empty" "$CONFIG_FILE")
    config_model=$(jq -r "${config_scope}.model // empty" "$CONFIG_FILE")
    config_base_url=$(jq -r "${config_scope}.base_url // empty" "$CONFIG_FILE")

    if [[ "$allow_top_level_fallback" == "true" ]]; then
        if [[ -z "$config_api_key" ]]; then
            config_api_key=$(jq -r '.api_key // empty' "$CONFIG_FILE")
        fi
        if [[ -z "$config_model" ]]; then
            config_model=$(jq -r '.model // empty' "$CONFIG_FILE")
        fi
        if [[ -z "$config_base_url" ]]; then
            config_base_url=$(jq -r '.base_url // empty' "$CONFIG_FILE")
        fi
    fi

    case "$AI_PROVIDER" in
        claude)
            if [[ -n "$config_api_key" ]]; then
                ANTHROPIC_API_KEY="$config_api_key"
            fi
            if [[ -n "$config_base_url" ]]; then
                CLAUDE_API_URL=$(resolve_claude_api_url "$config_base_url")
            fi
            ;;
        openai)
            if [[ -n "$config_api_key" ]]; then
                OPENAI_API_KEY="$config_api_key"
            fi
            if [[ -n "$config_base_url" ]]; then
                OPENAI_API_URL=$(resolve_openai_api_url "$config_base_url")
            fi
            ;;
        gemini)
            if [[ -n "$config_api_key" ]]; then
                GEMINI_API_KEY="$config_api_key"
            fi
            if [[ -n "$config_base_url" ]]; then
                GEMINI_API_URL=$(resolve_gemini_api_url "$config_base_url")
            fi
            ;;
    esac

    if [[ -n "$config_model" ]]; then
        GIT_AI_COMMIT_MODEL="$config_model"
    fi
}

# Check if we're in a git repository
check_git_repo() {
    debug "Checking if current directory is a git repository"
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        error "Not in a git repository"
    fi
    debug "Git repository check passed"
}

# Check if required tools and API keys are available
check_dependencies() {
    debug "Checking dependencies for provider: $AI_PROVIDER"
    
    # Check for curl or wget
    if ! command -v curl &> /dev/null && ! command -v wget &> /dev/null; then
        error "curl or wget is required for HTTP requests"
    fi
    debug "HTTP client check passed (curl/wget available)"
    
    # Check for jq
    if ! command -v jq &> /dev/null; then
        warn "jq not found - JSON parsing may fail"
    else
        debug "jq check passed"
    fi
    
    # Check API key based on provider
    case $AI_PROVIDER in
        claude)
            if [[ -z "$ANTHROPIC_API_KEY" ]]; then
                error "ANTHROPIC_API_KEY environment variable is required for Claude provider"
            fi
            debug "Claude API key configured"
            debug "Using Claude API URL: $CLAUDE_API_URL"
            ;;
        openai)
            if [[ -z "$OPENAI_API_KEY" ]]; then
                warn "OPENAI_API_KEY is not set; continuing without Authorization header"
            fi
            debug "OpenAI API key configured: $([[ -n "$OPENAI_API_KEY" ]] && echo yes || echo no)"
            debug "Using OpenAI API URL: $OPENAI_API_URL"
            ;;
        gemini)
            if [[ -z "$GEMINI_API_KEY" ]]; then
                error "GEMINI_API_KEY environment variable is required for Gemini provider"
            fi
            debug "Gemini API key configured"
            debug "Using Gemini API URL: $GEMINI_API_URL"
            ;;
        *)
            error "Unsupported AI provider: $AI_PROVIDER"
            ;;
    esac
}

build_git_diff_args() {
    local args=()

    if [[ "$STAGED_ONLY" == "true" ]]; then
        args+=(--staged)
    fi

    args+=(--find-renames)

    if [[ "$INCLUDE_CONTEXT" == "true" ]]; then
        args+=(--unified=5)
    else
        args+=(--unified=3)
    fi

    printf '%s\n' "${args[@]}"
}

build_git_summary_args() {
    local args=()

    if [[ "$STAGED_ONLY" == "true" ]]; then
        args+=(--staged)
    fi

    args+=(--find-renames)
    printf '%s\n' "${args[@]}"
}

build_file_diff_excerpt() {
    local file_path="$1"
    local line_budget="$2"
    local -a diff_args=()
    local file_diff=""
    local total_lines=0

    mapfile -t diff_args < <(build_git_diff_args)
    file_diff=$(git diff "${diff_args[@]}" -- "$file_path" 2>/dev/null)

    if [[ -z "$file_diff" ]]; then
        return 0
    fi

    total_lines=$(printf '%s\n' "$file_diff" | wc -l | awk '{print $1}')

    if (( total_lines <= line_budget )); then
        printf '%s\n' "$file_diff"
        return 0
    fi

    printf '%s\n' "$file_diff" | sed -n "1,${line_budget}p"
    printf '[truncated file excerpt: showing first %d of %d lines for %s]\n' "$line_budget" "$total_lines" "$file_path"
}

build_diff_analysis() {
    local -a diff_args=()
    local -a summary_args=()
    local diff_stat=""
    local name_status=""
    local full_diff=""
    local total_lines=0
    local analysis=""
    local file_impact_summary=""
    local file_patch_sections=""
    local files_without_patch=""
    local min_file_excerpt_lines=30
    local remaining_patch_budget=0
    local remaining_files=0
    local file_count=0
    local -a files=()
    local -A file_status=()

    debug "Getting git diff with options - staged-only mode: $STAGED_ONLY, all-changes mode: $ALL_CHANGES, context: $INCLUDE_CONTEXT"

    mapfile -t diff_args < <(build_git_diff_args)
    mapfile -t summary_args < <(build_git_summary_args)

    diff_stat=$(git diff "${summary_args[@]}" --stat 2>/dev/null)
    name_status=$(git diff "${summary_args[@]}" --name-status 2>/dev/null)
    full_diff=$(git diff "${diff_args[@]}" 2>/dev/null)

    if [[ -z "$name_status" && -z "$full_diff" ]]; then
        error "No staged changes found"
    fi

    total_lines=$(printf '%s\n' "$full_diff" | wc -l | awk '{print $1}')
    debug "Git diff captured successfully (${total_lines} lines)"

    analysis+="Git diff overview"$'\n'
    analysis+="Diff stat:"$'\n'
    analysis+="${diff_stat:-<empty>}"$'\n\n'
    analysis+="Name status:"$'\n'
    analysis+="${name_status:-<empty>}"$'\n'

    if (( MAX_DIFF_LINES <= 0 || total_lines <= MAX_DIFF_LINES )); then
        analysis+=$'\n'"Patch detail:"$'\n'
        analysis+="${full_diff:-<empty>}"$'\n'
        echo "$analysis"
        return 0
    fi

    warn "Large diff detected (${total_lines} lines). Building per-file excerpts within ${MAX_DIFF_LINES} lines." >&2

    while IFS=$'\t' read -r status primary_path secondary_path; do
        local file_path=""

        [[ -z "$status" ]] && continue

        if [[ "$status" == R* || "$status" == C* ]]; then
            file_path="${secondary_path:-$primary_path}"
        else
            file_path="$primary_path"
        fi

        files+=("$file_path")
        file_status["$file_path"]="$status"
    done <<< "$name_status"

    file_count=${#files[@]}
    remaining_patch_budget=$MAX_DIFF_LINES
    remaining_files=$file_count

    for file_path in "${files[@]}"; do
        local numstat_line=""
        local added="?"
        local deleted="?"
        local status_code="${file_status[$file_path]}"
        local file_excerpt=""
        local excerpt_lines=0
        local per_file_budget=0

        numstat_line=$(git diff "${summary_args[@]}" --numstat -- "$file_path" 2>/dev/null | sed -n '1p')
        if [[ -n "$numstat_line" ]]; then
            added=$(printf '%s\n' "$numstat_line" | awk '{print $1}')
            deleted=$(printf '%s\n' "$numstat_line" | awk '{print $2}')
        fi

        file_impact_summary+="- ${status_code} ${file_path} (+${added}/-${deleted})"$'\n'

        if (( remaining_files > 0 )); then
            per_file_budget=$(( remaining_patch_budget / remaining_files ))
        fi

        if (( per_file_budget < min_file_excerpt_lines )); then
            files_without_patch+="- ${status_code} ${file_path}"$'\n'
            remaining_files=$((remaining_files - 1))
            continue
        fi

        file_excerpt=$(build_file_diff_excerpt "$file_path" "$per_file_budget")
        if [[ -n "$file_excerpt" ]]; then
            excerpt_lines=$(printf '%s\n' "$file_excerpt" | wc -l | awk '{print $1}')
            file_patch_sections+="### ${status_code} ${file_path}"$'\n'
            file_patch_sections+="$file_excerpt"$'\n\n'
            remaining_patch_budget=$((remaining_patch_budget - excerpt_lines))
            if (( remaining_patch_budget < 0 )); then
                remaining_patch_budget=0
            fi
        else
            files_without_patch+="- ${status_code} ${file_path}"$'\n'
        fi

        remaining_files=$((remaining_files - 1))
    done

    analysis+=$'\n'"File impact summary:"$'\n'
    analysis+="${file_impact_summary:-<empty>}"$'\n'

    if [[ -n "$file_patch_sections" ]]; then
        analysis+="Per-file patch excerpts:"$'\n'
        analysis+="$file_patch_sections"
    fi

    if [[ -n "$files_without_patch" ]]; then
        analysis+="Files without patch excerpts due to size budget:"$'\n'
        analysis+="$files_without_patch"
    fi

    echo "$analysis"
}

build_commit_prompt() {
    local diff_analysis="$1"

    cat <<EOF
Generate a git commit message from the structured git change data below.

Return exactly this template:

type(scope): short summary

- summarize change group 1 [file-or-module-scope]
- summarize change group 2 [file-or-module-scope]
- summarize change group 3 [file-or-module-scope]

Requirements:
- The first line must be a conventional commit subject in the form type(scope): short summary.
- Add a blank line between the subject and the bullet list body.
- Use 3 to 6 bullet points in the body.
- Cover all major change groups in one message.
- Each body bullet must end with [relevant file path(s) or module scope].
- Prefer representative files or directories over exhaustive file lists.
- Body bullets must describe behavior changes and any compatibility or risk notes when relevant.
- Mention tests or documentation changes when they exist. Do not invent them when they do not exist.
- For compatibility, risk, test, or docs bullets, include files when they materially improve clarity.
- Keep the subject concise and the body informative.
- Do not output markdown fences, labels, explanations, or any text before or after the commit message.

Structured git change data:
$diff_analysis
EOF
}

sanitize_commit_message() {
    local raw_message="$1"

    printf '%s\n' "$raw_message" | awk '
        /^[[:space:]]*```[[:alnum:]_-]*[[:space:]]*$/ { next }
        /^[[:space:]]*[Cc]ommit message:[[:space:]]*$/ { next }
        { lines[++count] = $0 }
        END {
            start = 1
            while (start <= count && lines[start] ~ /^[[:space:]]*$/) {
                start++
            }

            end = count
            while (end >= start && lines[end] ~ /^[[:space:]]*$/) {
                end--
            }

            for (i = start; i <= end; i++) {
                print lines[i]
            }
        }
    '
}

# Make HTTP request using curl or wget
make_http_request() {
    local url="$1"
    local headers="$2"
    local data="$3"
    local header_args=""
    
    debug "Making HTTP request to: $url"
    debug "Request headers: Content-Type: application/json $headers"
    debug "Request data length: $(echo "$data" | wc -c) characters"

    if [[ -n "$headers" ]]; then
        header_args="--header \"$headers\""
    fi
    
    # Show request body for debugging (pretty-printed JSON if possible)
    if [[ "$DEBUG_MODE" == "true" || "$DEBUG_MODE" == "1" ]]; then
        local formatted_json
        if command -v jq &> /dev/null; then
            formatted_json=$(echo "$data" | jq . 2>/dev/null) || formatted_json="$data"
        else
            formatted_json="$data"
        fi
        debug "Request body: $formatted_json"
    fi
    
    local response
    if command -v curl &> /dev/null; then
        debug "Using curl for HTTP request"
        
        # For logging purposes, create a display-friendly version of the command
        # where the data payload is safely escaped.
        if [[ "$DEBUG_MODE" == "true" || "$DEBUG_MODE" == "1" ]]; then
            local safe_data_for_log
            printf -v safe_data_for_log '%q' "$data"
            # Note: The logged command is a representation. The actual execution uses a pipe.
            # The header string is intentionally not quoted to allow shell word splitting.
            debug "Executing command (representation): echo $safe_data_for_log | curl -s -X POST '$url' --header 'Content-Type: application/json' $header_args --data-binary @-"
        fi
        
        # Execute the command by piping the data to curl. This is safer than using eval
        # on the data, as it avoids shell parsing issues with special characters.
        # We still use eval to parse the headers string, which may contain multiple,
        # quoted arguments for providers like Claude. The URL is single-quoted
        # to protect it from being modified by eval.
        response=$(echo "$data" | eval "curl -s -X POST '$url' --header 'Content-Type: application/json' $header_args --data-binary @-")

    elif command -v wget &> /dev/null; then
        debug "Using wget for HTTP request"
        
        if [[ "$DEBUG_MODE" == "true" || "$DEBUG_MODE" == "1" ]]; then
            local safe_data_for_log
            printf -v safe_data_for_log '%q' "$data"
            debug "Executing command (representation): echo $safe_data_for_log | wget -q -O- --header='Content-Type: application/json' $header_args --post-data=@- '$url'"
        fi
        
        # The original implementation for wget was already using a pipe.
        # We add `eval` for consistency in header parsing, although it's less likely to be needed for wget.
        response=$(echo "$data" | eval "wget -q -O- --header='Content-Type: application/json' $header_args --post-data=@- '$url'")
    else
        error "Neither curl nor wget available"
    fi
    
    local response_length=$(echo "$response" | wc -c)
    debug "HTTP response received: $response_length characters"
    
    # Show response for debugging (pretty-printed JSON if possible)
    if [[ "$DEBUG_MODE" == "true" || "$DEBUG_MODE" == "1" ]]; then
        local formatted_response
        if command -v jq &> /dev/null; then
            formatted_response=$(echo "$response" | jq . 2>/dev/null) || formatted_response="$response"
        else
            formatted_response="$response"
        fi
        
        # Limit output length for readability
        if [[ ${#formatted_response} -gt 1000 ]]; then
            local preview=$(echo "$formatted_response" | head -c 1000)
            debug "Response body (truncated): $preview..."
        else
            debug "Response body: $formatted_response"
        fi
    fi
    
    echo "$response"
}


# Generate commit message using Claude API
generate_commit_message_claude() {
    local diff_content="$1"
    local model="${GIT_AI_COMMIT_MODEL:-$CLAUDE_MODEL}"
    local prompt=""
    
    debug "Generating commit message using Claude API with model: $model"
    prompt=$(build_commit_prompt "$diff_content")

    local json_data=$(cat <<EOF
{
    "model": "$model",
    "max_tokens": 220,
    "messages": [
        {
            "role": "user",
            "content": $(echo "$prompt" | jq -Rs .)
        }
    ]
}
EOF
)

    debug "Calling Claude API..."
    local response
    response=$(make_http_request "$CLAUDE_API_URL" \
               "\"x-api-key: $ANTHROPIC_API_KEY\" -H \"anthropic-version: 2023-06-01\"" \
               "$json_data")
    
    if [[ $? -ne 0 ]]; then
        debug "Claude API call failed"
        error "Failed to call Claude API"
    fi
    
    debug "Claude API response received, parsing..."
    
    # Check for API errors first
    local error_message=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
    if [[ -n "$error_message" ]]; then
        debug "Claude API returned error: $error_message"
        error "Claude API error: $error_message"
    fi
    
    # Extract message content from response
    local commit_message
    commit_message=$(echo "$response" | jq -r '.content[0].text' 2>/dev/null) || {
        debug "Failed to parse Claude API response. Raw response: $response"
        error "Failed to parse Claude API response"
    }
    
    debug "Claude API parsing successful. Commit message: '$commit_message'"
    echo "$commit_message"
}

# Generate commit message using OpenAI API
generate_commit_message_openai() {
    local diff_content="$1"
    local model="${GIT_AI_COMMIT_MODEL:-$OPENAI_MODEL}"
    local prompt=""
    
    debug "Generating commit message using OpenAI API with model: $model"
    prompt=$(build_commit_prompt "$diff_content")

    local json_data=$(cat <<EOF
{
    "model": "$model",
    "max_tokens": 220,
    "messages": [
        {
            "role": "user",
            "content": $(echo "$prompt" | jq -Rs .)
        }
    ]
}
EOF
)

    debug "Calling OpenAI API..."
    local response
    local auth_header=""

    if [[ -n "$OPENAI_API_KEY" ]]; then
        auth_header="Authorization: Bearer $OPENAI_API_KEY"
    fi

    response=$(make_http_request "$OPENAI_API_URL" \
               "$auth_header" \
               "$json_data")
    
    if [[ $? -ne 0 ]]; then
        debug "OpenAI API call failed"
        error "Failed to call OpenAI API"
    fi
    
    debug "OpenAI API response received, parsing..."
    
    # Check for API errors first
    local error_message=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
    if [[ -n "$error_message" ]]; then
        debug "OpenAI API returned error: $error_message"
        error "OpenAI API error: $error_message"
    fi
    
    # Extract message content from response
    local commit_message
    commit_message=$(echo "$response" | jq -r '.choices[0].message.content' 2>/dev/null) || {
        debug "Failed to parse OpenAI API response. Raw response: $response"
        error "Failed to parse OpenAI API response"
    }
    
    debug "OpenAI API parsing successful. Commit message: '$commit_message'"
    echo "$commit_message"
}

# Generate commit message using Gemini API
generate_commit_message_gemini() {
    local diff_content="$1"
    local model="${GIT_AI_COMMIT_MODEL:-$GEMINI_MODEL}"
    local prompt=""
    
    debug "Generating commit message using Gemini API with model: $model"
    prompt=$(build_commit_prompt "$diff_content")

    # Check if API key starts with 'sk' to determine API format
    if echo "$GEMINI_API_KEY" | grep -q "^sk"; then
        debug "Using OpenAI-compatible Gemini API format (sk key detected)"
        
        local json_data=$(cat <<EOF
{
    "model": "$model",
    "messages": [
        {
            "role": "user",
            "content": $(echo "$prompt" | jq -Rs .)
        }
    ]
}
EOF
)

        local api_url="${GEMINI_API_URL}/chat/completions"
        local auth_header="Authorization: Bearer $GEMINI_API_KEY"
        
        debug "Calling Gemini API (OpenAI-compatible)..."
        local response
        response=$(make_http_request "$api_url" \
                   "$auth_header" \
                   "$json_data")
        
        if [[ $? -ne 0 ]]; then
            debug "Gemini API call failed"
            error "Failed to call Gemini API"
        fi
        
        debug "Gemini API response received, parsing..."
        
        # Check for API errors first
        local error_message=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
        if [[ -n "$error_message" ]]; then
            debug "Gemini API returned error: $error_message"
            error "Gemini API error: $error_message"
        fi
        
        # Parse response (OpenAI-compatible format)
        local commit_message
        commit_message=$(echo "$response" | jq -r '.choices[0].message.content' 2>/dev/null) || {
            debug "Failed to parse Gemini API response. Raw response: $response"
            error "Failed to parse Gemini API response"
        }
        
    else
        debug "Using Google AI Gemini API format (non-sk key detected)"
        
        local json_data=$(cat <<EOF
{
    "contents": [
        {
            "parts": [
                {
                    "text": $(echo "$prompt" | jq -Rs .)
                }
            ]
        }
    ]
}
EOF
)

        local api_url="${GEMINI_API_URL}/models/$model:generateContent"
        local auth_header="X-goog-api-key: $GEMINI_API_KEY"
        
        debug "Calling Gemini API (Google AI format)..."
        local response
        response=$(make_http_request "$api_url" \
                   "$auth_header" \
                   "$json_data")
        
        if [[ $? -ne 0 ]]; then
            debug "Gemini API call failed"
            error "Failed to call Gemini API"
        fi
        
        debug "Gemini API response received, parsing..."
        
        # Check for API errors first
        local error_message=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
        if [[ -n "$error_message" ]]; then
            debug "Gemini API returned error: $error_message"
            error "Gemini API error: $error_message"
        fi
        
        # Parse response (Google AI format)
        local commit_message
        commit_message=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text' 2>/dev/null) || {
            debug "Failed to parse Gemini API response. Raw response: $response"
            error "Failed to parse Gemini API response"
        }
        
    fi
    
    debug "Gemini API parsing successful. Commit message: '$commit_message'"
    echo "$commit_message"
}

# Generate commit message using AI
generate_commit_message() {
    local diff_content="$1"
    
    case $AI_PROVIDER in
        claude)
            generate_commit_message_claude "$diff_content"
            ;;
        openai)
            generate_commit_message_openai "$diff_content"
            ;;
        gemini)
            generate_commit_message_gemini "$diff_content"
            ;;
        *)
            error "Unsupported AI provider: $AI_PROVIDER"
            ;;
    esac
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--staged)
                ALL_CHANGES=false
                STAGED_ONLY=true
                shift
                ;;
            -a|--all)
                ALL_CHANGES=true
                STAGED_ONLY=true
                shift
                ;;
            -c|--context)
                INCLUDE_CONTEXT=true
                shift
                ;;
            -d|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -p|--provider)
                AI_PROVIDER="$2"
                CLI_PROVIDER_SET=true
                shift 2
                ;;
            -l|--limit)
                MAX_DIFF_LINES="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                error "Unknown option: $1. Use --help for usage information."
                ;;
        esac
    done
}

# Main execution
main() {
    parse_args "$@"
    load_config
    normalize_provider_api_urls
    
    debug "Starting git-ai-commit with the following configuration:"
    debug "- AI Provider: $AI_PROVIDER"
    debug "- Staged Only: $STAGED_ONLY"
    debug "- All Changes: $ALL_CHANGES"
    debug "- Include Context: $INCLUDE_CONTEXT"
    debug "- Dry Run: $DRY_RUN"
    debug "- Max Diff Lines: $MAX_DIFF_LINES"
    debug "- Debug Mode: $DEBUG_MODE"
    
    info "Checking git repository..."
    check_git_repo
    
    info "Checking dependencies..."
    check_dependencies

    prepare_commit_scope
    
    info "Analyzing changes..."
    local diff_content
    diff_content=$(build_diff_analysis)
    
    info "Generating commit message using $AI_PROVIDER..."
    local commit_message
    commit_message=$(generate_commit_message "$diff_content")
    
    if [[ -z "$commit_message" ]]; then
        debug "Empty commit message received from AI provider"
        error "Failed to generate commit message"
    fi
    
    debug "Raw commit message from AI: '$commit_message'"
    
    # Clean up the commit message while preserving subject + body structure
    commit_message=$(sanitize_commit_message "$commit_message")

    if [[ -z "$commit_message" ]]; then
        debug "Commit message became empty after cleanup"
        error "Failed to generate commit message"
    fi
    
    debug "Cleaned commit message: '$commit_message'"
    
    echo
    echo -e "${GREEN}Generated commit message:${NC}"
    print_commit_message_preview "$commit_message"
    echo
    
    if [[ "$DRY_RUN" == "true" ]]; then
        info "Dry run mode - not committing"
        debug "Exiting due to dry run mode"
        exit 0
    fi
    
    # Ask for confirmation
    read -p "Do you want to commit with this message? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        debug "User confirmed commit"

        info "Creating commit..."
        COMMIT_MESSAGE_FILE=$(mktemp "${TMPDIR:-/tmp}/git-ai-commit.XXXXXX")
        trap cleanup_commit_message_file EXIT
        printf '%s\n' "$commit_message" > "$COMMIT_MESSAGE_FILE"
        debug "Running: git commit -F \"$COMMIT_MESSAGE_FILE\""
        git commit -F "$COMMIT_MESSAGE_FILE"
        cleanup_commit_message_file
        trap - EXIT
        success "Commit created successfully!"
    else
        info "Commit cancelled"
        debug "User cancelled commit"
    fi
}

# Run main function with all arguments
main "$@"
